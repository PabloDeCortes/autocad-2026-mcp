{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "eslint/no-underscore-dangle": ["error", { "allow": ["_tag"] }],
    "unicorn/prefer-add-event-listener": "off"
  },
  "ignorePatterns": ["node_modules", "dist", ".repos"]
}
